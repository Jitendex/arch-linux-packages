# Maintainer: Stephen Kraus (github.com/stephenmk)

pkgname=edrdg-dictionary-archive-utils
pkgver=20260723.0
_pkg="${pkgname}-${pkgver}"
pkgrel=1
pkgdesc='Software for reading and updating data in the EDRDG dictionary archive'
arch=('any')
url='https://github.com/Jitendex/edrdg-dictionary-archive-utils'
license=('Apache-2.0')
depends=('fish' 'git' 'rsync' 'brotli' 'grep' 'patch' 'diffutils' 'gnupg')
makedepends=()
source=(
    "${url}/releases/download/${pkgver}/${_pkg}.tar.gz"
    'gitconfig'
    'gpg-public-key'
    'gpg-private-key'
    'git-credentials'
)
sha512sums=(
    'daf9d8e2cb7709b434fece5e742326559073ae9d458a66b0b8df1090915e0575d36c13b9bf2730bf39343cfd55fde979a2bff6096e7a0b944634844279ec741c'
    '9e9df333df033d3e1559e1c8a0fc0f8c9fc5c808fc3a0e0b7e729caa5e3883c33189070cca9899cc0f18d85fbc50e6fa1277e069f92ccc87cf7705418e239d94'
    '316d76866e84dd8d2ec8dde2a0b9437f4ca0c812e35d7510fa5adcba0a7c2e63416112533ac3c06cf776454e26b23126809d978011ffd1e89152dce02f9087e1'
    'SKIP'
    'SKIP'
)
install="${pkgname}.install"
_servicename='edrdg-dictionary-archive-update'

package() {
    cd "$srcdir"

    ### the main script ###
    install -Dm755 \
            "$_pkg"/edrdg_dictionary_archive.fish \
            "$pkgdir"/usr/bin/edrdg_dictionary_archive

    ### documentation files ###
    install -Dm644 \
            "$_pkg"/README.md \
            -t "$pkgdir"/usr/share/doc/"$pkgname"/

    install -Dm644 \
            "$_pkg"/LICENSE \
            -t "$pkgdir"/usr/share/licenses/"$pkgname"/

    ### systemd files ###
    install -Dm644 \
            "$_pkg"/systemd/edrdg-dictionary-archive-update.{timer,service} \
            -t "$pkgdir"/usr/lib/systemd/system/

    install -Dm644 \
            "$_pkg"/systemd/"$_servicename".sysusers \
            "$pkgdir"/usr/lib/sysusers.d/"$_servicename".conf

    install -Dm644 \
            "$_pkg"/systemd/"$_servicename".tmpfiles \
            "$pkgdir"/usr/lib/tmpfiles.d/"$_servicename".conf

    ### credential and config files ###
    install -Dm644 \
            gitconfig \
            "$pkgdir"/usr/share/"$_servicename"/.gitconfig

    install -Dm644 \
            gpg-public-key \
            "$pkgdir"/usr/share/"$_servicename"/gpg-public-key.asc

    install -dm700 \
            "$pkgdir"/usr/share/"$_servicename"/secrets/

    install -Dm600 \
            gpg-private-key \
            "$pkgdir"/usr/share/"$_servicename"/secrets/gpg-private-key.asc

    install -Dm600 \
            git-credentials \
            "$pkgdir"/usr/share/"$_servicename"/secrets/.git-credentials
}
